# ========================================
# Server Configuration
# ========================================

# HTTP server port
PORT=3000

# HTTP server host (0.0.0.0 binds to all interfaces)
HOST=0.0.0.0

# Base path for all API routes (e.g., /api/v1)
BASE_PATH=/

# Trust proxy headers (true/false) - Enable if running behind Nginx/Cloudflare
TRUST_PROXY=false

# ========================================
# Authentication
# ========================================

# API key for authentication (required for all endpoints except health)
# Generate with: openssl rand -base64 32
API_KEY=your-secure-api-key-here

# ========================================
# Session Management
# ========================================

# Restore sessions on server startup (true/false)
RESTORE_SESSIONS_ON_STARTUP=true

# Directory for WhatsApp authentication data
SESSIONS_PATH=./sessions

# Mark incoming messages as seen/read automatically (true/false)
SET_MESSAGES_AS_SEEN=false

# ========================================
# Rate Limiting
# ========================================

# Rate limit window in milliseconds
RATE_LIMIT_WINDOW_MS=1000

# Maximum requests per window
RATE_LIMIT_MAX=1000

# ========================================
# Webhook Configuration
# ========================================

# Global webhook URL for all sessions (optional)
BASE_WEBHOOK_URL=

# Enable webhook delivery (true/false)
ENABLE_WEBHOOK=true

# Pipe-separated list of callback events to disable (e.g., message_received|chat_updated)
DISABLED_CALLBACKS=

# ========================================
# WebSocket Configuration
# ========================================

# Enable WebSocket event streaming (true/false)
ENABLE_WEBSOCKET=false

# Enable Swagger/OpenAPI documentation (true/false)
# Access docs at /api-docs when enabled
ENABLE_SWAGGER=true

# ========================================
# CORS Configuration
# ========================================

# Allowed origins (comma-separated or * for all)
CORS_ORIGINS=*

# ========================================
# Logging
# ========================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# ========================================
# Media Configuration
# ========================================

# Maximum attachment size (bytes) - Default: 10MB
MAX_ATTACHMENT_SIZE=10485760
