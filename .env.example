# Server Configuration
PORT=3000

# Authentication
API_KEY=your-api-key-here

# Webhook Configuration
BASE_WEBHOOK_URL=https://example.com/webhook
ENABLE_WEBHOOK=true

# WebSocket Configuration
ENABLE_WEBSOCKET=false

# File Upload Configuration
MAX_ATTACHMENT_SIZE=10485760

# Message Settings
SET_MESSAGES_AS_SEEN=false

# Callback Configuration (pipe-separated list of disabled callbacks)
DISABLED_CALLBACKS=callback1|callback2

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=1000

# Session Management
RECOVER_SESSIONS=true
SESSIONS_PATH=./sessions

# Logging
LOG_LEVEL=info

# Base Path and CORS
BASE_PATH=/
CORS_ORIGINS=*

# Proxy Trust
TRUST_PROXY=false
